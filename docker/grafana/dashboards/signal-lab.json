{
  "title": "Signal Lab",
  "uid": "signal-lab",
  "schemaVersion": 38,
  "version": 1,
  "refresh": "5s",
  "time": { "from": "now-1h", "to": "now" },
  "panels": [
    {
      "id": 1,
      "title": "Scenario Runs Total",
      "type": "timeseries",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum by (type, status) (increase(scenario_runs_total[5m]))"
        }
      ],
      "gridPos": { "x": 0, "y": 0, "w": 12, "h": 8 }
    },
    {
      "id": 2,
      "title": "Error Rate %",
      "type": "gauge",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "100 * sum(rate(scenario_errors_total[5m])) / sum(rate(scenario_runs_total[5m]))"
        }
      ],
      "gridPos": { "x": 12, "y": 0, "w": 6, "h": 8 }
    },
    {
      "id": 3,
      "title": "Duration P99 (seconds)",
      "type": "stat",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "histogram_quantile(0.99, rate(scenario_duration_seconds_bucket[5m]))"
        }
      ],
      "gridPos": { "x": 18, "y": 0, "w": 6, "h": 8 }
    },
    {
      "id": 4,
      "title": "Application Logs",
      "type": "logs",
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "loki" },
          "expr": "{app=\"signal-lab\"}",
          "refId": "A"
        }
      ],
      "gridPos": { "x": 0, "y": 8, "w": 24, "h": 12 }
    }
  ]
}
